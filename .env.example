NODE_ENV=development
DATABASE_URL=postgresql://journey:journey@localhost:5432/journey_dev
REDIS_URL=redis://localhost:6379
TENANT_CONFIG_PATH=./seed/elgris.tenant-config.json

# Gates the sync worker's cron scheduler (15-min incremental + nightly full
# reconcile) started from server.ts. Set to "false" to boot the API without
# the scheduler running — e.g. local dev, tests, or a deploy where sync work
# has been deliberately paused. Any other value (or unset) leaves it enabled.
ENABLE_SYNC=true
