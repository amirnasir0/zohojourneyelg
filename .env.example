NODE_ENV=development
DATABASE_URL=postgresql://journey:journey@localhost:5432/journey_dev
REDIS_URL=redis://localhost:6379
TENANT_CONFIG_PATH=./seed/elgris.tenant-config.json

# Gates the sync worker's cron scheduler (15-min incremental + nightly full
# reconcile) started from server.ts. Set to "false" to boot the API without
# the scheduler running — e.g. local dev, tests, or a deploy where sync work
# has been deliberately paused. Any other value (or unset) leaves it enabled.
ENABLE_SYNC=true

# Shared secret Zoho Workflow Rule webhooks must send (as a query param or a
# JSON body field named "secret") to POST /webhooks/zoho/*. Generate a long
# random value, e.g. `openssl rand -hex 24`. See docs/ZOHO-WEBHOOK-SETUP.md.
WEBHOOK_SECRET=

# Comma-separated allowlist of browser origins allowed to call this API
# cross-origin (e.g. "https://admin.elgris.in,https://staging.elgris.in").
# Unset/empty denies every browser origin outright. This does NOT affect the
# React Native app — CORS is a browser-only enforcement mechanism, and native
# HTTP requests from the RN app never send an Origin header, so they're
# unaffected regardless of this setting.
CORS_ORIGINS=

# TEMPORARY support/debug bypass (see src/routes/auth.ts) — when set, this
# value passed as the OTP to POST /auth/verify-otp logs into ANY customer's
# account by mobile number, no real OTP needed. Hard-expires 2026-08-16
# regardless of this var. Leave unset in normal operation; only set it for
# the deliberate testing window, and unset + remove the code afterward
# rather than letting it linger.
UNIVERSAL_TEST_OTP=
