generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StageHistorySource {
  WEBHOOK
  SYNC
}

model TenantConfig {
  id        String   @id @default(uuid())
  config    Json
  version   Int      @default(1)
  updatedAt DateTime @updatedAt

  @@map("tenant_config")
}

model Contact {
  id             String   @id @default(uuid())
  zohoContactId  String   @unique @map("zoho_contact_id")
  // Nullable: resolved lazily on first ticket creation (search/create against
  // Desk), not backfilled by the CRM contact sync. A collision here would mean
  // two local contacts got bridged to the same Desk contact — real data
  // corruption worth failing loudly on, hence @unique rather than a soft check.
  deskContactId  String?  @unique @map("desk_contact_id")
  mobileE164     String   @unique @map("mobile_e164")
  altMobileE164  String?  @map("alt_mobile_e164")
  fullName       String?  @map("full_name")
  email          String?
  raw            Json
  syncedAt       DateTime @map("synced_at")

  journeys       Journey[]
  sessions       Session[]
  deviceTokens   DeviceToken[]
  tickets        Ticket[]

  @@index([altMobileE164])
  @@map("contacts")
}

model Journey {
  id            String   @id @default(uuid())
  zohoRecordId  String   @unique @map("zoho_record_id")
  contactId     String   @map("contact_id")
  name          String
  stage         String
  stageIndex    Int?     @map("stage_index")
  refValues     Json     @map("ref_values")
  raw           Json
  syncedAt      DateTime @map("synced_at")

  contact       Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  stageHistory  StageHistory[]

  @@map("journeys")
}

model StageHistory {
  id         String             @id @default(uuid())
  journeyId  String             @map("journey_id")
  fromStage  String?            @map("from_stage")
  toStage    String             @map("to_stage")
  changedAt  DateTime           @map("changed_at")
  source     StageHistorySource
  // `${journeyId}:${toStage}:${minuteBucket}` — real DB-level idempotency for
  // webhook redelivery (PRD §11.2: dedupe on record_id + to_stage + minute
  // bucket) instead of a race-prone check-then-insert. A duplicate delivery
  // hits this unique constraint (P2002), caught and treated as a no-op.
  dedupeKey  String             @unique @map("dedupe_key")

  journey    Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@map("stage_history")
}

model Ticket {
  id            String    @id @default(uuid())
  deskTicketId  String    @unique @map("desk_ticket_id")
  contactId     String    @map("contact_id")
  ticketNumber  String    @map("ticket_number")
  subject       String
  description   String?
  category      String?
  status        String
  statusDisplay String    @map("status_display")
  ownerName     String?   @map("owner_name")
  coOwnerName   String?   @map("co_owner_name")
  priority      String?
  // Mirrors Desk's own closedTime (confirmed live: ISO timestamp set the
  // moment status flips to Closed, cleared back to null on reopen) — not
  // derived/computed locally, so a reopen-then-reclose is reflected exactly
  // as Desk reports it, no local state to drift.
  closedAt      DateTime? @map("closed_at")
  createdAt     DateTime  @map("created_at")
  updatedAt     DateTime  @map("updated_at")
  // Local write timestamp, distinct from createdAt/updatedAt (which mirror
  // Desk's own createdTime/modifiedTime) — lets sync tell "when did our copy
  // last touch this row" apart from "when did Zoho's record last change."
  syncedAt      DateTime  @map("synced_at")
  raw           Json

  contact       Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@map("tickets")
}

model OtpAttempt {
  id         String   @id @default(uuid())
  mobileE164 String   @map("mobile_e164")
  attempts   Int      @default(0)
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("otp_attempts")
}

model Session {
  id         String    @id @default(uuid())
  contactId  String    @map("contact_id")
  jti        String    @unique
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  contact    Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model DeviceToken {
  id         String   @id @default(uuid())
  contactId  String   @map("contact_id")
  token      String
  platform   String
  createdAt  DateTime @default(now()) @map("created_at")

  contact    Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@map("device_tokens")
}

// One row per sync stream ('incremental' | 'full_reconcile'). Feeds /healthz/sync.
model SyncState {
  id                String    @id @default(uuid())
  key               String    @unique
  watermark         DateTime?
  lastRunAt         DateTime? @map("last_run_at")
  lastRunStatus     String?   @map("last_run_status")
  contactsProcessed Int       @default(0) @map("contacts_processed")
  journeysProcessed Int       @default(0) @map("journeys_processed")
  ticketsProcessed  Int       @default(0) @map("tickets_processed")
  issuesCount       Int       @default(0) @map("issues_count")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Checkpoint for interruption-resilient runs (Fix 5). Written in the same
  // transaction as each page's batch commit, so it can never drift from
  // actual data. Non-null checkpointPhase means a run is (or was) mid-flight;
  // on startup this is what "resume from page N" reads from instead of
  // restarting at page 1. checkpointSinceIso/checkpointRunStartedAt are the
  // *original* run's values, reused verbatim on resume rather than
  // recomputed, so the eventual watermark reflects when the run actually
  // started, not when it happened to finish.
  checkpointPhase        String?   @map("checkpoint_phase")
  checkpointPageToken    String?   @map("checkpoint_page_token")
  checkpointPagesDone    Int       @default(0) @map("checkpoint_pages_done")
  checkpointSinceIso     String?   @map("checkpoint_since_iso")
  checkpointRunStartedAt DateTime? @map("checkpoint_run_started_at")

  @@map("sync_state")
}

// Diagnostic log: bad phone numbers, unknown stages, orphan journeys, duplicate mobiles.
// Deduped on (zohoRecordId, field, reason) via skipDuplicates — one row per
// distinct problem, not one row per occurrence across every sync run.
model SyncIssue {
  id           String   @id @default(uuid())
  zohoRecordId String?  @map("zoho_record_id")
  recordType   String   @map("record_type")
  field        String?
  rawValue     String?  @map("raw_value")
  reason       String
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([zohoRecordId, field, reason])
  @@index([recordType, createdAt])
  @@map("sync_issues")
}
